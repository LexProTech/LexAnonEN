{
  "manifest_version": 3,
  "name": "LexAnon EN",
  "version": "1.0.0",
  "description": "Local anonymization of personal data in .docx files. File never leaves the browser.",
  "permissions": ["downloads", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LexAnon EN"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/jszip.min.js",
        "lib/validators.js",
        "lib/entity-finder.js",
        "lib/replacer.js",
        "lib/docx-parser.js",
        "worker/processor.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
